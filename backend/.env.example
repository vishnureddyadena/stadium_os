# STADIUM OS CORE API — CONFIGURATION TEMPLATE

# 1. Supabase PostgreSQL connection string URI (retrieve from Database -> Connection string)
# Replace [YOUR-PASSWORD] with the database password you created when building the project.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxx.supabase.co:5432/postgres

# 2. Secret Key for JWT Token Generation (Keep secret and generate random string)
SECRET_KEY=stadium_os_ai_secret_super_secure_key_2026_fifa

# 3. Optional Gemini API Key for Command Center GenAI Copilot
GEMINI_API_KEY=your_gemini_api_key_here
